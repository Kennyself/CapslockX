<Window x:Class="CapslockX.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CapslockX Settings" Height="450" Width="600"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="CapslockX" FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="CapsLock as a powerful modifier key."
                       FontSize="14" Foreground="Gray"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Settings UI coming in Phase 4."
                       FontSize="12" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>